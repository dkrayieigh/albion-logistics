{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "albion-logistics",
  "version": "0.4.2",
  "identifier": "com.albion.logistics",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Albion Logistics v0.4.2",
        "width": 1360,
        "height": 820,
        "minWidth": 1200,
        "minHeight": 768,
        "decorations": false,
        "resizable": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
